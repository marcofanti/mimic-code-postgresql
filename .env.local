# .env.local — Example configuration for MIMIC-IV PostgreSQL setup
# Copy this file to .env and fill in your actual values.
# .env is gitignored; .env.local is committed as documentation.

# ---------------------------------------------------------------------------
# PostgreSQL credentials
# These are used by build_mimic.py and passed to docker run commands.
# ---------------------------------------------------------------------------

# Name of the PostgreSQL database to create/use
POSTGRES_DB=mimiciv

# PostgreSQL superuser credentials (used to create schemas and load data)
POSTGRES_USER=mimicuser
POSTGRES_PASSWORD=change_me_strong_password

# Port exposed on the host machine (mapped to container port 5432)
POSTGRES_PORT=5432

# ---------------------------------------------------------------------------
# Docker settings
# ---------------------------------------------------------------------------

# Name for the running PostgreSQL container
DB_CONTAINER_NAME=mimic_postgres

# Tag for the built PostgreSQL Docker image (built from docker/Dockerfile.db)
DB_IMAGE_NAME=mimic-db

# Docker network name — all containers join this network to communicate
DOCKER_NETWORK=mimic-net

# ---------------------------------------------------------------------------
# Data paths
# ---------------------------------------------------------------------------

# Absolute path to the root of your downloaded MIMIC-IV data.
# This directory must contain the following subdirectories:
#   hosp/   — hospital module CSV files (admissions.csv.gz, patients.csv.gz, ...)
#   icu/    — ICU module CSV files (chartevents.csv.gz, icustays.csv.gz, ...)
#
# Example (macOS):  /Users/yourname/data/mimic-iv/3.1
# Example (Linux):  /home/yourname/data/mimic-iv/3.1
MIMIC_DATA_DIR=/path/to/mimic-iv/3.1

# Path to the cloned mimic-code repository (relative to project root or absolute).
# The build script uses: $MIMIC_CODE_DIR/mimic-iv/buildmimic/postgres/*.sql
# Clone with: git clone https://github.com/MIT-LCP/mimic-code.git
MIMIC_CODE_DIR=./mimic-code

# Absolute path to the directory containing MIMIC-IV-Note CSV.gz files.
# This should point to the `note/` subdirectory of the downloaded mimic-iv-note dataset.
# Example (macOS):  /Users/yourname/data/mimic-iv-note/2.2/note
# Example (Linux):  /home/yourname/data/mimic-iv-note/2.2/note
# Used by build_mimic_notes.ipynb to build the mimiciv_note schema.
MIMIC_NOTE_DATA_DIR=/path/to/mimic-iv-note/2.2/note

# ---------------------------------------------------------------------------
# Data loading limits
# ---------------------------------------------------------------------------

# Path to a JSON file specifying per-table row limits during data loading.
# The JSON must have the shape: { "default": N, "overrides": { "table": N } }
# If set, the loader pipes each table's CSV through head to cap row count.
# Leave empty (or unset) to load all rows with no limits applied.
# See limits.json for a working example.
LOAD_LIMITS_FILE=./limits.json
